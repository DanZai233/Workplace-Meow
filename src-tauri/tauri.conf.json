{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "职场桌宠",
  "version": "0.1.0",
  "identifier": "com.workplace.meow",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "职场桌宠",
        "url": "index.html",
        "shadow": false,
        "alwaysOnTop": true,
        "transparent": true,
        "decorations": false,
        "acceptFirstMouse": true,
        "skipTaskbar": true,
        "center": false,
        "width": 520,
        "height": 460,
        "x": 100,
        "y": 100
      },
      {
        "label": "settings",
        "url": "index.html#/settings",
        "visible": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "width": 920,
        "height": 720,
        "minWidth": 900,
        "minHeight": 700,
        "decorations": true,
        "skipTaskbar": false,
        "center": true
      },
      {
        "label": "chat",
        "url": "index.html#/chat",
        "visible": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "width": 420,
        "height": 620,
        "minWidth": 400,
        "minHeight": 600,
        "decorations": false,
        "skipTaskbar": false,
        "transparent": true,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**/*"],
          "requireLiteralLeadingDot": false
        }
      }
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "copyright": "",
    "externalBin": [],
    "icon": [],
    "longDescription": "",
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    },
    "resources": ["assets/models"],
    "shortDescription": "",
    "targets": "all"
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "store": {}
  }
}
